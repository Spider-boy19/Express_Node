<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="style.css">
    <title>Document</title>
</head>
    <body>
        <h1>Welcome to George's Words of the day</h1>
        <p>Every time you visit all the words will be shown</p>
        <p>Here are the words!</p>
        <% allwords.forEach(function(wordItem){ %>
            <p>
                <%= wordItem.word %> - <%= wordItem.part %>
                <%= wordItem.definition %>
            </p>
       <% }) %>
    </body>
</html>